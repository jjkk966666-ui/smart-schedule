# ===========================
# OpenAI API 配置 - 普通用户
# ===========================
# 必需：OpenAI API 密钥（用于普通用户的AI功能）
OPENAI_API_KEY=sk-your-openai-api-key-here

# 可选：自定义 AI 模型名称（默认：gpt-4-turbo-preview）
# OPENAI_MODEL_NAME=gpt-4-turbo-preview
# 其他可选模型示例：
# OPENAI_MODEL_NAME=gpt-3.5-turbo
# OPENAI_MODEL_NAME=gpt-4
# OPENAI_MODEL_NAME=gpt-4o

# 可选：自定义 API 基础 URL（用于使用第三方兼容 API）
# OPENAI_BASE_URL=https://api.openai.com/v1

# ===========================
# Premium API 配置 - VIP用户
# ===========================
# 可选：VIP用户专用的高级API密钥
# PREMIUM_API_KEY=sk-your-premium-api-key-here

# 可选：VIP用户专用的API基础URL
# PREMIUM_BASE_URL=https://api.openai.com/v1

# 可选：VIP用户专用的AI模型名称
# PREMIUM_MODEL_NAME=gpt-4o

# ===========================
# 数据库配置
# ===========================
# 使用 SQLite（默认路径：./prisma/dev.db）
# DATABASE_URL="file:./prisma/dev.db"

# ===========================
# JWT 认证配置
# ===========================
JWT_SECRET=your-secret-key-here

# ===========================
# 管理员配置
# ===========================
# 管理员接口访问密钥（用于生成VIP通行证等管理功能）
# 访问方式：GET /api/admin/generate-passports?secret=your-admin-secret-here
ADMIN_SECRET=your-admin-secret-here

# ===========================
# 服务器配置
# ===========================
PORT=3000