# 数据库配置
# 开发环境: 使用 PostgreSQL (建议) 或 SQLite
DATABASE_URL=postgresql://user:password@localhost:5432/smart_schedule
# 或使用 SQLite: DATABASE_URL="file:./prisma/dev.db"

# 生产环境 (Render): 使用 Render 提供的 PostgreSQL Internal URL
# DATABASE_URL=从 Render PostgreSQL Dashboard 复制

# JWT配置
# 生产环境请使用至少 32 位的强随机密钥
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI配置
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# 服务器配置
PORT=3000
NODE_ENV=development

# CORS配置
# 开发环境
CORS_ORIGIN=http://localhost:5173
# 生产环境 (部署后更新为你的 Vercel 前端域名)
# CORS_ORIGIN=https://your-app.vercel.app

# 速率限制配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100