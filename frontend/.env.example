# API配置
#
# 本地开发时使用：
# VITE_API_BASE_URL=http://localhost:3000/api
#
# VS Code 端口转发/生产环境使用相对路径（留空或注释掉即可自动使用相对路径）：
# VITE_API_BASE_URL=/api
#
# 如果前端和后端运行在不同的转发端口，指定完整URL：
# VITE_API_BASE_URL=https://your-forwarded-backend-url.app.github.dev/api

# 默认值（开发环境）
VITE_API_BASE_URL=http://localhost:3000/api