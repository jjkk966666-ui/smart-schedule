# ====================================
# 🔒 敏感文件 - 绝对不要上传！
# ====================================

# 环境变量文件（包含密钥、数据库密码等）
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# ====================================
# 📦 依赖目录
# ====================================
node_modules/
**/node_modules/
.pnp
.pnp.js

# ====================================
# 🏗️ 构建输出
# ====================================
build/
dist/
**/dist/
*.tsbuildinfo

# ====================================
# 🧪 测试
# ====================================
coverage/
.nyc_output

# ====================================
# 📝 日志
# ====================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ====================================
# 💻 编辑器和IDE
# ====================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ====================================
# 🗄️ 数据库文件
# ====================================
*.db
*.sqlite
*.sqlite3
backend/prisma/*.db
backend/prisma/dev.db

# ====================================
# 🔧 Prisma
# ====================================
# 注意：migrations 目录需要保留，用于生产环境部署

# ====================================
# 💾 操作系统
# ====================================
Thumbs.db
.DS_Store
*.tmp
*.temp
.cache

# ====================================
# 📦 包管理器锁文件（可选保留）
# ====================================
# 如果想锁定版本，可以注释掉这些行
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ====================================
# 📁 项目特定
# ====================================
backend/uploads/*
!backend/uploads/.gitkeep
frontend/.vite/