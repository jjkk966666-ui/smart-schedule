# 智能日程表系统 - 生产环境变量示例

# JWT 密钥 (生产环境请使用强密钥，至少32字符)
JWT_SECRET=your-production-secret-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-production-refresh-secret-key-minimum-32-characters-long

# OpenAI API 密钥 (可选 - 用于AI增强功能)
OPENAI_API_KEY=sk-your-openai-api-key-here

# 数据库配置 (Docker会自动处理)
# 如需修改，请同时更新 docker-compose.yml
DATABASE_URL=file:/app/data/prod.db

# CORS 配置
CORS_ORIGIN=http://localhost:5173